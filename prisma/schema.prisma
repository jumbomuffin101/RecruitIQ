generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum CandidateStatus {
  APPLIED
  SCREENED
  INTERVIEW
  OFFER
  REJECTED
}

enum ActivityType {
  CANDIDATE_CREATED
  JOB_CREATED
  STATUS_CHANGED
  ANALYSIS_GENERATED
  NOTE_ADDED
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  users        User[]
  jobs         Job[]
  candidates   Candidate[]
  applications Application[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Job {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  department     String
  location       String
  type           JobType       @default(FULL_TIME)
  description    String
  requirements   String
  status         JobStatus     @default(OPEN)
  applications   Application[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Candidate {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  email             String
  phone             String?
  location          String?
  linkedinUrl       String?
  githubUrl         String?
  educationSummary String?
  currentTitle      String?
  currentCompany    String?
  projectsSummary   String?
  yearsExperience   Float?
  resumeSummary     String?
  roleAppliedFor    String
  resumeText        String
  skills            String[]
  experienceSummary String
  status            CandidateStatus @default(APPLIED)
  notes             String?
  applications      Application[]
  resumeAnalyses    ResumeAnalysis[]
  interviewKits     InterviewKit[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([organizationId, email])
}

model Application {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateId    String
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status         CandidateStatus @default(APPLIED)
  fitScore       Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([candidateId, jobId])
}

model ResumeAnalysis {
  id               String    @id @default(cuid())
  candidateId      String
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId            String?
  fitScore         Int
  summary          String
  roleMatch        String?
  strengths        String[]
  gaps             String[]
  recommendedStage String
  nextStep         String?
  technicalQuestions String[] @default([])
  behavioralQuestions String[] @default([])
  resumeSpecificQuestions String[] @default([])
  source           String    @default("deterministic")
  createdAt        DateTime  @default(now())
}

model InterviewKit {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId       String?
  questions   String[]
  focusAreas  String[]
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           ActivityType
  message        String
  metadata       Json?
  createdAt      DateTime     @default(now())
}
