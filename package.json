{
  "name": "recruitiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/*.test.ts",
    "test:db:reset": "tsx scripts/test-db-reset.ts",
    "test:integration": "npm run test:db:reset && tsx --test tests/integration/**/*.test.ts",
    "test:e2e": "npm run test:db:reset && playwright test",
    "test:e2e:ui": "npm run test:db:reset && playwright test --ui",
    "ci": "prisma generate && prisma validate && npm run lint && npm test && npm run test:integration && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@prisma/client": "^6.16.3",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "^6.16.3",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
